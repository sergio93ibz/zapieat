# =============================================================================
# ZAPIEAT — Variables de entorno para PRODUCCIÓN
# =============================================================================
#
# INSTRUCCIONES:
#   1. Copia este archivo: cp deploy/.env.production.example .env
#   2. Rellena TODOS los valores marcados con <CAMBIAR>
#   3. NUNCA subas el archivo .env al repositorio (ya está en .gitignore)
#
# =============================================================================


# -----------------------------------------------------------------------------
# URLs DE LA APLICACIÓN
# -----------------------------------------------------------------------------

NEXT_PUBLIC_APP_URL=https://zapieat.app
NEXT_PUBLIC_BASE_DOMAIN=zapieat.app
NEXTAUTH_URL=https://zapieat.app


# -----------------------------------------------------------------------------
# BASE DE DATOS (PostgreSQL)
# NO cambiar el host "db" — apunta al contenedor Docker interno
# SÍ cambiar POSTGRES_PASSWORD por una contraseña segura
# -----------------------------------------------------------------------------

POSTGRES_USER=zasfood
POSTGRES_PASSWORD=<CAMBIAR_por_password_segura>
POSTGRES_DB=zasfood

# DATABASE_URL debe definirse aquí explícitamente.
# IMPORTANTE: si la password tiene caracteres especiales, codifícalos:
#   @  ->  %40
#   #  ->  %23
#   !  ->  %21
#   $  ->  %24
# Ejemplo con password "Mi@Pass#123": usar "Mi%40Pass%23123"
DATABASE_URL=postgresql://zasfood:<CAMBIAR_misma_password_que_POSTGRES_PASSWORD>@db:5432/zasfood


# -----------------------------------------------------------------------------
# REDIS
# NO cambiar — apunta al contenedor Docker interno
# -----------------------------------------------------------------------------

REDIS_URL=redis://redis:6379


# -----------------------------------------------------------------------------
# SECRETOS DE AUTENTICACIÓN
# Generar AUTH_SECRET con:     openssl rand -base64 32
# Generar ENCRYPTION_KEY con:  openssl rand -hex 32
# -----------------------------------------------------------------------------

AUTH_SECRET=<CAMBIAR_generar_con_openssl_rand_-base64_32>
ENCRYPTION_KEY=<CAMBIAR_generar_con_openssl_rand_-hex_32>


# -----------------------------------------------------------------------------
# EMAIL (Resend — https://resend.com)
# -----------------------------------------------------------------------------

RESEND_API_KEY=<CAMBIAR_tu_api_key_de_resend>
EMAIL_FROM=noreply@zapieat.app


# -----------------------------------------------------------------------------
# PAGOS (Redsys)
# Cambiar a PRODUCTION solo cuando tengas las credenciales reales de Redsys
# -----------------------------------------------------------------------------

REDSYS_ENVIRONMENT=SANDBOX
